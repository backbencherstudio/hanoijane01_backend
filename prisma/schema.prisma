// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accountId    String    @map("account_id")
  providerId   String    @map("provider_id")
  accessToken  String?   @map("access_token")
  refreshToken String?   @map("refresh_token")
  idToken      String?   @map("id_token")
  expiresAt    DateTime? @map("expires_at")
  password     String?

  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?

  @@unique([providerId, accountId])
  @@index([userId])
  @@index([providerId])
  @@map("accounts")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @default(now()) @map("updated_at")

  @@index([identifier])
  @@index([expiresAt])
  @@map("verifications")
}

model User {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  approvedAt      DateTime? @map("approved_at")
  emailVerifiedAt DateTime? @map("email_verified_at")

  name           String?
  email          String? @unique
  companyName    String? @map("company_name") @db.VarChar(255)
  password       String? @db.VarChar(255)
  avatar         String?
  phoneNumber    String? @map("phone_number")
  companyAddress String? @map("company_address")
  companyBio     String? @map("company_bio") @db.Text
  websiteLink    String? @map("website_link")
  billingId      String? @map("billing_id")
  status         Int?    @default(1) @db.SmallInt
  type           String? @default("user")
  emailVerified  Boolean @default(false) @map("email_verified")

  isTwoFactorEnabled Int?    @default(0) @map("is_two_factor_enabled")
  twoFactorSecret    String? @map("two_factor_secret")

  accounts              Account[]
  sessions              Session[]
  receiverNotifications Notification[] @relation("receiver")
  senderNotifications   Notification[] @relation("sender")

  userSettings        UserSetting[]
  paymentTransactions PaymentTransaction[]
  bookings            Booking[]
  contacts            Contact[]

  @@map("users")
}

model NotificationEvent {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  status Int?    @default(1) @db.SmallInt
  type   String?
  text   String?

  notifications Notification[]

  @@map("notification_events")
}

model Notification {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  readAt DateTime? @map("read_at")

  status Int? @default(1) @db.SmallInt

  senderId String? @map("sender_id")
  sender   User?   @relation("sender", fields: [senderId], references: [id])

  receiverId String? @map("receiver_id")
  receiver   User?   @relation("receiver", fields: [receiverId], references: [id])

  notificationEventId String?            @map("notification_event_id")
  notificationEvent   NotificationEvent? @relation(fields: [notificationEventId], references: [id])

  entityId String? @map("entity_id")

  @@map("notifications")
}

model Setting {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  category     String?
  label        String?
  description  String?
  key          String? @unique
  defaultValue String? @map("default_value")

  userSettings UserSetting[]

  @@map("settings")
}

model UserSetting {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id])

  settingId String?  @map("setting_id")
  setting   Setting? @relation(fields: [settingId], references: [id])

  value String?

  @@map("user_settings")
}

model Exhibition {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  startedAt       DateTime? @map("started_at")
  endedAt         DateTime? @map("ended_at")
  bookingStatedAt DateTime? @map("booking_stated_at")
  bookingEndedAt  DateTime? @map("booking_ended_at")

  title       String?
  description String?
  slug        String?

  location String?

  stands Stand[]
  halls  Hall[]

  @@map("exhibitions")
}

model Hall {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  title String? @map("title")

  exhibitionId String?     @map("exhibition_id")
  exhibition   Exhibition? @relation(fields: [exhibitionId], references: [id])

  standCategories StandCategory[]

  @@map("halls")
}

model StandCategory {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  title String?
  slug  String  @unique
  size  String?

  priceInMinorUnit Int     @default(0) @map("price_in_minor_unit")
  price            Decimal @default(0.00) @db.Decimal(12, 2)
  vatPercentage    Decimal @default(0.00) @map("vat_percentage") @db.Decimal(5, 2)

  hallId String? @map("hall_id")
  hall   Hall?   @relation(fields: [hallId], references: [id])
  stands Stand[]

  @@map("stand_categories")
}

model Stand {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  title       String?
  standNumber String? @unique @map("stand_number")
  description String?

  isAvailable Int @default(1) @map("is_available") @db.SmallInt // 1 = available, 0 = not available

  exhibitionId String? @map("exhibition_id")
  categoryId   String? @map("category_id")

  exhibition Exhibition?    @relation(fields: [exhibitionId], references: [id])
  category   StandCategory? @relation(fields: [categoryId], references: [id])
  bookings   Booking[]

  @@map("stands")
}

model Booking {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  status Int @default(1) @db.SmallInt // 1 = booked, 0 = not booked

  userName       String? @map("user_name")
  companyName    String? @map("company_name")
  companyAddress String? @map("company_address")
  email          String?
  phoneNumber    String? @map("phone_number")

  subTotalAmount Decimal @default(0.00) @map("sub_total_amount") @db.Decimal(12, 2)
  discountAmount Decimal @default(0.00) @map("discount_amount") @db.Decimal(12, 2)
  vatAmount      Decimal @default(0.00) @map("vat_amount") @db.Decimal(12, 2)
  vatPercentage  Decimal @default(0.00) @map("vat_percentage") @db.Decimal(5, 2)
  totalAmount    Decimal @default(0.00) @map("total_amount") @db.Decimal(12, 2)

  paymentStatus           String?   @default("unpaid") @map("payment_status") // unpaid, paid, failed, refunded
  paymentMethod           String?   @default("stripe") @map("payment_method")
  currency                String?   @default("usd")
  stripeCustomerId        String?   @map("stripe_customer_id")
  stripePaymentIntentId   String?   @map("stripe_payment_intent_id")
  stripeCheckoutSessionId String?   @map("stripe_checkout_session_id")
  paidAt                  DateTime? @map("paid_at")

  userId  String? @map("user_id")
  standId String? @map("stand_id")

  user                User?                @relation(fields: [userId], references: [id])
  stand               Stand?               @relation(fields: [standId], references: [id])
  paymentTransactions PaymentTransaction[]

  @@map("bookings")
}

model PaymentTransaction {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  amount       Decimal? @db.Decimal(12, 2)
  currency     String?  @default("usd")
  paidAmount   Decimal? @map("paid_amount") @db.Decimal(12, 2)
  paidCurrency String?  @map("paid_currency")

  provider        String? @default("stripe")
  referenceNumber String? @map("reference_number")
  status          String? @default("pending") // pending, succeeded, failed, canceled
  rawStatus       String? @map("raw_status")

  stripeCustomerId        String? @map("stripe_customer_id")
  stripePaymentIntentId   String? @map("stripe_payment_intent_id")
  stripeCheckoutSessionId String? @map("stripe_checkout_session_id")
  stripeChargeId          String? @map("stripe_charge_id")
  receiptUrl              String? @map("receipt_url")

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id])

  bookingId String?  @map("booking_id")
  booking   Booking? @relation(fields: [bookingId], references: [id])

  @@map("payment_transactions")
}

model Contact {
  id          String  @id @default(cuid())
  name        String?
  companyName String?
  email       String
  phoneNumber String?
  message     String

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  @@map("contacts")
}

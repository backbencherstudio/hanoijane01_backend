// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accountId    String @map("account_id")
  providerId   String @map("provider_id")
  accessToken  String? @map("access_token")
  refreshToken String? @map("refresh_token")
  idToken      String? @map("id_token")
  expiresAt    DateTime? @map("expires_at")
  password     String?

  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?

  @@unique([providerId, accountId])
  @@index([userId])
  @@index([providerId])
  @@map("accounts")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @default(now()) @map("updated_at")

  @@index([identifier])
  @@index([expiresAt])
  @@map("verifications")
}

model User {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  approvedAt      DateTime? @map("approved_at")
  emailVerifiedAt DateTime? @map("email_verified_at")

  name           String?
  email          String? @unique
  companyName    String? @map("company_name") @db.VarChar(255)
  password       String? @db.VarChar(255)
  avatar         String?
  phoneNumber    String? @map("phone_number")
  companyAddress String? @map("company_address")
  billingId      String? @map("billing_id")
  status         Int?    @default(1) @db.SmallInt
  type           String? @default("user")
  emailVerified  Boolean @default(false) @map("email_verified")

  isTwoFactorEnabled Int?    @default(0) @map("is_two_factor_enabled")
  twoFactorSecret    String? @map("two_factor_secret") // secret key for two factor authentication

  accounts              Account[]
  sessions              Session[]
  receiverNotifications Notification[] @relation("receiver")
  senderNotifications   Notification[] @relation("sender")

  userPaymentMethods  UserPaymentMethod[]
  userSettings        UserSetting[]
  paymentTransactions PaymentTransaction[]

  @@map("users")
}

// this table stores notification event
model NotificationEvent {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  status Int?    @default(1) @db.SmallInt
  type   String?
  text   String?

  notifications Notification[]

  @@map("notification_events")
}

model Notification {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  readAt DateTime? @map("read_at")

  status Int? @default(1) @db.SmallInt

  senderId String? @map("sender_id")
  sender   User?   @relation("sender", fields: [senderId], references: [id])

  receiverId String? @map("receiver_id")
  receiver   User?   @relation("receiver", fields: [receiverId], references: [id])

  notificationEventId String?            @map("notification_event_id")
  notificationEvent   NotificationEvent? @relation(fields: [notificationEventId], references: [id])

  entityId String? @map("entity_id")

  @@map("notifications")
}

model UserPaymentMethod {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id])

  paymentMethodId String? @map("payment_method_id")
  checkoutId      String? @map("checkout_id")

  @@map("user_payment_methods")
}

model PaymentTransaction {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  storeId String? @map("store_id")

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id])

  orderId         String?  @map("order_id")
  type            String?  @default("order")
  withdrawVia     String?  @default("wallet") @map("withdraw_via")
  provider        String?
  referenceNumber String?  @map("reference_number")
  status          String?  @default("pending")
  rawStatus       String?  @map("raw_status")
  amount          Decimal?
  currency        String?
  paidAmount      Decimal? @map("paid_amount")
  paidCurrency    String?  @map("paid_currency")

  @@map("payment_transactions")
}

model Setting {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  category     String?
  label        String?
  description  String?
  key          String? @unique
  defaultValue String? @map("default_value")

  userSettings UserSetting[]

  @@map("settings")
}

model UserSetting {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id])

  settingId String?  @map("setting_id")
  setting   Setting? @relation(fields: [settingId], references: [id])

  value String?

  @@map("user_settings")
}
